  <div class="kpi kc-red"><div class="kpi-icon">⚠️</div><div class="kpi-label">Overdue</div><div class="kpi-val"><%=fmtNum(overdue_count)%></div></div>
  <div class="kpi kc-pink"><div class="kpi-icon">🔄</div><div class="kpi-label">R & R</div><div class="kpi-val"><%=fmtNum(rr_count)%></div></div>
  <div class="kpi kc-purple"><div class="kpi-icon">📊</div><div class="kpi-label">Approval Rate</div><div class="kpi-val"><%=approval_rate%>%</div></div>
</div>
<div class="card">
  <div class="card-header"><div class="card-title">Document Type Report with Approval Rate</div></div>
  <div class="tbl-wrap">
    <table class="dcs" id="registerTable">
      <thead><tr>
        <th>Doc Type</th>
        <%(statuses||[]).forEach(s=>{%><th><%=s%></th><%})%>
        <th>Total</th><th>Approved %</th>
      </tr></thead>
      <tbody>
      <%(doc_types||[]).forEach(type=>{%>
      <%const td=(documents||[]).filter(d=>d.type===type);const tt=td.length;const tap=td.filter(d=>d.status==='Approved').length;const tr2=tt?Math.round(tap/tt*100):0;%>
      <tr>
        <td><span class="chip"><%=type%></span></td>
        <%(statuses||[]).forEach(s=>{const v=td.filter(d=>d.status===s).length;%><td style="text-align:center;color:<%=v?sHex(s):'#d1d5db'%>;font-weight:<%=v?700:400%>;"><%=v||'—'%></td><%})%>
        <td style="text-align:center;font-weight:800;"><%=tt%></td>
        <td style="min-width:120px;">
          <div style="display:flex;align-items:center;gap:6px;">
            <div class="prog-bar" style="flex:1;"><div class="prog-fill" style="width:<%=tr2%>%;background:<%=tr2>=80?'#16a34a':tr2>=50?'#d97706':'#dc2626'%>;"></div></div>
            <span style="font-size:11px;font-weight:700;color:<%=tr2>=80?'#16a34a':tr2>=50?'#d97706':'#dc2626'%>;"><%=tr2%>%</span>
          </div>
        </td>
      </tr>
      <%})%>
      </tbody>
    </table>
  </div>
</div>
<%if(Object.keys(matrix||{}).length){%>
<div class="card">
  <div class="card-header"><div class="card-title">Discipline Analysis by Document Type</div></div>
  <div class="disc-grid">
  <%Object.keys(matrix||{}).sort().forEach(type=>{const discMap=matrix[type]||{};const discs=Object.keys(discMap).sort();const allSt2=statuses||[];%>
  <div class="disc-card">
    <div class="disc-card-hdr"><span class="disc-card-type"><%=type%></span><span class="disc-card-sub">Discipline Breakdown</span></div>
    <table class="disc-tbl">
      <thead><tr><th>Discipline</th><%allSt2.slice(0,4).forEach(s=>{%><th><%=s.length>7?s.slice(0,6)+'…':s%></th><%})%><th>Total</th><th>Rate</th></tr></thead>
      <tbody>
      <%let gTotal=0;discs.forEach(disc=>{const sm=discMap[disc]||{};const rowTot=Object.values(sm).reduce((a,b)=>a+b,0);gTotal+=rowTot;const apr=sm['Approved']||0;const rate2=rowTot?Math.round(apr/rowTot*100):0;%>
      <tr>
        <td><%=disc%></td>
        <%allSt2.slice(0,4).forEach(s=>{const v=sm[s]||0;%><td style="text-align:center;color:<%=v?sHex(s):'#d1d5db'%>;"><%=v||'—'%></td><%})%>
        <td style="text-align:center;font-weight:700;"><%=rowTot%></td>
        <td><span style="font-size:10px;font-weight:700;color:<%=rate2>=80?'#16a34a':rate2>=50?'#d97706':'#dc2626'%>;"><%=rate2%>%</span></td>
      </tr>
      <%});%>
      <tr class="dtr"><td>Total</td><%allSt2.slice(0,4).forEach(s=>{const gv=Object.values(discMap).reduce((a,dm)=>a+(dm[s]||0),0);%><td style="text-align:center;"><%=gv||'—'%></td><%})%><td style="text-align:center;"><%=gTotal%></td><td></td></tr>
      </tbody>
    </table>
  </div>
  <%});%>
  </div>
</div>
<%}%>
<%if(overdue_docs&&overdue_docs.length){%>
<div class="card">
  <div class="card-header"><div class="card-title" style="color:#dc2626;">⚠️ Overdue Documents (<%=overdue_docs.length%>)</div></div>
