      <%overdue_docs.forEach(d=>{%>
      <tr>
        <td><strong><%=d.doc_number%></strong></td><td><span class="chip"><%=d.type%></span></td>
        <td style="max-width:180px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%=d.title%></td>
        <td><%=d.discipline||'—'%></td><td><%- sPill(d.status) %></td><td><%=d.contractor||'—'%></td>
        <td><%=fmtDate(d.due_date)%></td><td class="days-overdue"><%=d.days_open%></td>
      </tr>
      <%})%>
      </tbody>
    </table>
  </div>
</div>
<%}%>

