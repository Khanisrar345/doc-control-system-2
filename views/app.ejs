<script>
function toggleSidebar(){document.getElementById('sidebar').classList.toggle('open');document.getElementById('sidebarOverlay').classList.toggle('open');}
function closeSidebar(){document.getElementById('sidebar').classList.remove('open');document.getElementById('sidebarOverlay').classList.remove('open');}
function openModal(id){document.getElementById(id).classList.add('open');}
function closeModal(id){document.getElementById(id).classList.remove('open');}
document.addEventListener('keydown',e=>{if(e.key==='Escape')document.querySelectorAll('.modal-overlay.open').forEach(m=>m.classList.remove('open'));});

function switchTab(el,targetId){
  el.closest('.tab-bar').querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
  document.getElementById(targetId).classList.add('active');
}

function openStatusModal(id,docNum,status){
  document.getElementById('statusDocId').value=id;
  document.getElementById('statusDocNum').value=docNum;
  const sel=document.getElementById('statusSel');
  if(sel){for(const o of sel.options){if(o.value===status){o.selected=true;break;}}}
  openModal('statusModal');
}

function openEditUser(id,name,email,uname,company,phone,dept,role,active){
  document.getElementById('editUserId').value=id;
  document.getElementById('euName').value=name;
  document.getElementById('euEmail').value=email;
  document.getElementById('euUsername').value=uname;
  document.getElementById('euCompany').value=company;
  document.getElementById('euPhone').value=phone;
  document.getElementById('euDept').value=dept;
  const rs=document.getElementById('euRole');
  if(rs)for(const o of rs.options){if(o.value===role){o.selected=true;break;}}
  const as=document.getElementById('euActive');
  if(as)for(const o of as.options){if(o.value===active){o.selected=true;break;}}
  openModal('editUserModal');
}

function openResetPw(id,name){
  document.getElementById('rpUserId').value=id;
  document.getElementById('rpUserName').textContent=name;
  openModal('resetPwModal');
}

function doPrint(){
  const orient=document.querySelector('input[name=pOrient]:checked').value;
  const size=document.getElementById('pSize').value;
  let sty=document.getElementById('printOrientStyle');
  if(!sty){sty=document.createElement('style');sty.id='printOrientStyle';document.head.appendChild(sty);}
  sty.textContent='@page{size:'+size+' '+orient+';margin:10mm;}';
  closeModal('printModal');
  setTimeout(window.print,150);
}

function exportCSV(){
  const tbl=document.getElementById('registerTable');
  if(!tbl){alert('No table to export.');return;}
  let csv=[];
  for(const row of tbl.rows){
    const cells=[...row.cells].map(c=>'"'+c.innerText.replace(/"/g,'""').replace(/\n/g,' ').trim()+'"');
    csv.push(cells.join(','));
  }
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([csv.join('\n')],{type:'text/csv'}));
  a.download='DCS_Export_'+new Date().toISOString().split('T')[0]+'.csv';
  a.click();
}

function doSearch(val){
  if(!val.trim())return;
  window.location.href='/app?page=document_register&search='+encodeURIComponent(val.trim());
}

const importFile=document.getElementById('importFile');
const importBtn=document.getElementById('importBtn');
const importResult=document.getElementById('importResult');
if(importFile){
  importFile.addEventListener('change',()=>{
    if(importBtn)importBtn.disabled=!importFile.files.length;
    if(importFile.files.length&&importBtn)importBtn.innerHTML='<i class="fa-solid fa-database"></i> Import: '+importFile.files[0].name;
  });
}
async function doImport(){
  if(!importFile||!importFile.files.length)return;
  if(importBtn){importBtn.disabled=true;importBtn.innerHTML='<i class="fa-solid fa-spinner fa-spin"></i> Importing…';}
  if(importResult){importResult.style.display='block';importResult.textContent='Processing…';importResult.style.color='#d97706';}
  try{
    const text=await importFile.files[0].text();
    const json=JSON.parse(text);
    const res=await fetch('/import-json',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(json)});
    const d=await res.json();
    if(d.error){
      if(importResult){importResult.textContent='❌ '+d.error;importResult.style.color='#dc2626';}
    }else{
      if(importResult){importResult.textContent='✅ Imported '+d.imported+' documents, '+d.skipped+' skipped.';importResult.style.color='#16a34a';}
      setTimeout(()=>location.reload(),2000);
    }
  }catch(e){
    if(importResult){importResult.textContent='❌ Error: '+e.message;importResult.style.color='#dc2626';}
  }
  if(importBtn){importBtn.disabled=false;importBtn.innerHTML='<i class="fa-solid fa-database"></i> Import';}
}

function triggerLogoUpload(field){document.getElementById('logoInput_'+field).click();}
async function uploadLogo(field,input){
  if(!input.files.length)return;
  const fd=new FormData();fd.append('logo',input.files[0]);fd.append('field',field);
  const res=await fetch('/upload-logo',{method:'POST',body:fd});
  const d=await res.json();
  if(d.ok){location.reload();}else{alert('Upload failed: '+(d.error||'Unknown error'));}
}

<%if(page==='dashboard'){%>
(async()=>{
  try{
    const r=await fetch('/api/stats');
    const d=await r.json();
    const PAL=['#1a7a7a','#6366f1','#f59e0b','#ef4444','#8b5cf6','#f97316','#34d399','#60a5fa','#ec4899','#84cc16','#06b6d4','#f43f5e','#a78bfa','#fb923c'];
    function sc(s){
      const m={'Approved':'#16a34a','Under Review':'#d97706','Open':'#0f766e','Pending':'#ea580c','Rejected':'#dc2626','Closed':'#6b7280','Revise & Resubmit':'#db2777','Submitted':'#1e40af','Returned':'#4f46e5'};
      if(m[s])return m[s];
      let h=0;for(const c of s)h+=c.charCodeAt(0);
      return PAL[h%PAL.length];
    }
    const opts={responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}}};

    const tl=Object.keys(d.by_type||{}).sort((a,b)=>d.by_type[b]-d.by_type[a]);
    if(tl.length){
      new Chart(document.getElementById('chartType'),{
        type:'bar',
        data:{labels:tl,datasets:[{data:tl.map(k=>d.by_type[k]),backgroundColor:tl.map((x,i)=>PAL[i%PAL.length]),borderRadius:5}]},
        options:Object.assign({},opts,{scales:{y:{beginAtZero:true,ticks:{stepSize:1}},x:{ticks:{font:{size:11}}}}})
      });
    }
    const sl=Object.keys(d.by_status||{});
    if(sl.length){
      new Chart(document.getElementById('chartStatus'),{
        type:'doughnut',
        data:{labels:sl,datasets:[{data:sl.map(k=>d.by_status[k]),backgroundColor:sl.map(s=>sc(s)),borderWidth:2,borderColor:'#fff'}]},
        options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'right',labels:{font:{size:11},padding:8,boxWidth:12}}}}
      });
    }
    const ml=(d.monthly||[]).map(m=>m._id.year+'-'+String(m._id.month).padStart(2,'0'));
    const mv=(d.monthly||[]).map(m=>m.count);
    if(ml.length){
      new Chart(document.getElementById('chartMonthly'),{
        type:'line',
        data:{labels:ml.map(m=>{const p=m.split('-');return new Date(p[0],p[1]-1).toLocaleString('en',{month:'short',year:'2-digit'});}),
          datasets:[{data:mv,borderColor:'<%=PC%>',backgroundColor:'rgba(26,122,122,.08)',fill:true,tension:.4,pointRadius:4,pointBackgroundColor:'<%=AC%>'}]},
        options:Object.assign({},opts,{scales:{y:{beginAtZero:true},x:{ticks:{font:{size:10}}}}})
      });
    }
    const dl=Object.keys(d.by_discipline||{}).sort((a,b)=>d.by_discipline[b]-d.by_discipline[a]).slice(0,12);
    if(dl.length){
      new Chart(document.getElementById('chartDisc'),{
        type:'bar',
        data:{labels:dl,datasets:[{data:dl.map(k=>d.by_discipline[k]),backgroundColor:'<%=PC%>',borderRadius:4}]},
        options:Object.assign({},opts,{indexAxis:'y',scales:{x:{beginAtZero:true},y:{ticks:{font:{size:10}}}}})
      });
    }
  }catch(e){console.error('Chart error:',e);}
})();
<%}%>
</script>
</body>
</html>
