      <%let typeTotal=0;const grandRow={};discs.forEach(disc=>{const sm=discMap[disc]||{};const rowTotal=Object.values(sm).reduce((a,b)=>a+b,0);typeTotal+=rowTotal;allSt.forEach(s=>{grandRow[s]=(grandRow[s]||0)+(sm[s]||0);});%>
      <tr>
        <td><%=disc%></td>
        <%allSt.slice(0,5).forEach(s=>{const v=sm[s]||0;%><td style="text-align:center;color:<%=v?sHex(s):'#d1d5db'%>;"><%=v||'—'%></td><%})%>
