<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover"/>
<meta name="theme-color" content="<%= settings.primary_color||'#1a7a7a' %>"/>
<meta name="mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<title>DCS — <%= (page||'dashboard').replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase()) %></title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<style>
:root{
  --pc:<%= settings.primary_color||'#1a7a7a' %>;
  --ac:<%= settings.accent_color||'#23a6a6' %>;
  --sidebar:#0f1923;--sidebar2:#162230;--sidebar3:#1d2d3e;
  --bg:#f0f4f8;--white:#fff;--surface:#fff;
  --text:#1a2332;--muted:#6b7280;--border:#e5eaef;
  --radius:14px;--radius-sm:9px;
  --shadow:0 2px 12px rgba(0,0,0,.07);--shadow-lg:0 8px 40px rgba(0,0,0,.15);
  --sidebar-w:260px;--topbar-h:60px;--font:'Inter',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:var(--font);background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}

/* SIDEBAR */
.sidebar{position:fixed;top:0;left:0;width:var(--sidebar-w);height:100vh;background:var(--sidebar);display:flex;flex-direction:column;z-index:200;overflow-y:auto;transition:transform .3s cubic-bezier(.4,0,.2,1);}
.sidebar::-webkit-scrollbar{width:3px;} .sidebar::-webkit-scrollbar-thumb{background:rgba(255,255,255,.1);border-radius:2px;}
.sidebar-brand{padding:18px 16px 14px;border-bottom:1px solid rgba(255,255,255,.06);display:flex;align-items:center;gap:10px;flex-shrink:0;}
.brand-icon{width:38px;height:38px;border-radius:10px;flex-shrink:0;background:linear-gradient(135deg,var(--pc),var(--ac));display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;color:#fff;}
.brand-text .t1{font-size:13px;font-weight:700;color:#fff;line-height:1.2;}
.brand-text .t2{font-size:10px;color:rgba(255,255,255,.35);letter-spacing:.3px;}
.nav-section{padding:10px 8px 2px;}
.nav-label{font-size:9px;font-weight:700;color:rgba(255,255,255,.25);letter-spacing:1.2px;text-transform:uppercase;padding:0 8px;margin-bottom:4px;}
.nav-item{display:flex;align-items:center;gap:9px;padding:9px 10px;border-radius:var(--radius-sm);margin-bottom:1px;color:rgba(255,255,255,.5);font-size:13px;font-weight:500;text-decoration:none;cursor:pointer;transition:all .15s;}
.nav-item:hover{background:rgba(255,255,255,.07);color:rgba(255,255,255,.9);}
.nav-item.active{background:var(--pc);color:#fff;box-shadow:0 4px 12px rgba(26,122,122,.35);}
.nav-item i{width:16px;text-align:center;font-size:13px;flex-shrink:0;}
.sidebar-bottom{margin-top:auto;padding:10px 8px;border-top:1px solid rgba(255,255,255,.06);}
.sidebar-credit{font-size:10px;color:rgba(255,255,255,.18);text-align:center;padding:6px 0;line-height:1.5;}
.sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:199;}

/* TOPBAR */
.topbar{position:fixed;top:0;left:var(--sidebar-w);right:0;height:var(--topbar-h);background:var(--white);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 20px;gap:12px;z-index:100;box-shadow:var(--shadow);}
.topbar-toggle{display:none;background:none;border:none;font-size:20px;cursor:pointer;color:var(--muted);padding:4px;}
.topbar-title{font-size:16px;font-weight:700;color:var(--text);flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.topbar-search{display:flex;align-items:center;gap:8px;background:var(--bg);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:6px 12px;transition:border-color .2s;}
.topbar-search:focus-within{border-color:var(--pc);}
.topbar-search i{color:var(--muted);font-size:13px;}
.topbar-search input{border:none;background:none;outline:none;font-size:13px;width:160px;font-family:var(--font);}
.tb-btn{width:36px;height:36px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--white);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--muted);transition:all .18s;text-decoration:none;position:relative;}
.tb-btn:hover{border-color:var(--pc);color:var(--pc);}
.tb-dot{position:absolute;top:-3px;right:-3px;width:9px;height:9px;background:#ef4444;border-radius:50%;border:2px solid #fff;}
.user-chip{display:flex;align-items:center;gap:8px;background:var(--bg);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:5px 10px 5px 5px;cursor:pointer;}
.user-av{width:28px;height:28px;border-radius:7px;object-fit:cover;}
.user-info .uname{font-size:12px;font-weight:600;line-height:1.2;}
.user-info .urole{font-size:10px;color:var(--muted);}

/* MAIN */
.main{margin-left:var(--sidebar-w);padding-top:var(--topbar-h);min-height:100vh;display:flex;flex-direction:column;}
.content{padding:20px 22px;flex:1;}

/* ALERT */
.alert-success{background:#f0fdf4;border:1px solid #86efac;color:#15803d;border-radius:var(--radius-sm);padding:10px 14px;font-size:13px;display:flex;align-items:center;gap:8px;margin-bottom:14px;animation:slideDown .3s ease;}
@keyframes slideDown{from{opacity:0;transform:translateY(-8px);}to{opacity:1;transform:none;}}

/* CARDS */
.card{background:var(--surface);border-radius:var(--radius);box-shadow:var(--shadow);border:none;padding:20px;margin-bottom:16px;}
.card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;gap:10px;flex-wrap:wrap;}
.card-title{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text);}
.card-badge{background:var(--bg);color:var(--muted);font-size:10px;padding:3px 8px;border-radius:6px;font-weight:600;white-space:nowrap;}

/* KPI */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(145px,1fr));gap:12px;margin-bottom:18px;}
.kpi{background:var(--white);border-radius:var(--radius);padding:18px 16px 14px;border-left:4px solid var(--border);box-shadow:var(--shadow);transition:transform .2s,box-shadow .2s;}
.kpi:hover{transform:translateY(-2px);box-shadow:var(--shadow-lg);}
.kpi-icon{font-size:18px;margin-bottom:7px;}
.kpi-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:3px;}
.kpi-val{font-size:30px;font-weight:800;line-height:1;margin-bottom:2px;}
.kpi-sub{font-size:10px;color:var(--muted);}
.kc-teal{border-left-color:var(--pc);} .kc-teal .kpi-val{color:var(--pc);}
.kc-green{border-left-color:#16a34a;} .kc-green .kpi-val{color:#16a34a;}
.kc-amber{border-left-color:#d97706;} .kc-amber .kpi-val{color:#d97706;}
.kc-red{border-left-color:#dc2626;} .kc-red .kpi-val{color:#dc2626;}
.kc-indigo{border-left-color:#6366f1;} .kc-indigo .kpi-val{color:#6366f1;}
.kc-purple{border-left-color:#7c3aed;} .kc-purple .kpi-val{color:#7c3aed;}
.kc-orange{border-left-color:#ea580c;} .kc-orange .kpi-val{color:#ea580c;}
.kc-slate{border-left-color:#64748b;} .kc-slate .kpi-val{color:#64748b;}
.kc-pink{border-left-color:#db2777;} .kc-pink .kpi-val{color:#db2777;}
.kc-sky{border-left-color:#0284c7;} .kc-sky .kpi-val{color:#0284c7;}

/* CHIPS & PILLS */
.chip{display:inline-block;padding:2px 8px;border-radius:5px;background:#1a2332;color:#fff;font-size:10px;font-weight:700;letter-spacing:.3px;}
.pill{display:inline-block;padding:3px 10px;border-radius:20px;font-size:10px;font-weight:700;letter-spacing:.2px;}
.pill-green{background:#dcfce7;color:#15803d;} .pill-amber{background:#fef3c7;color:#92400e;}
.pill-teal{background:#ccfbf1;color:#0f766e;} .pill-orange{background:#ffedd5;color:#9a3412;}
.pill-red{background:#fee2e2;color:#991b1b;} .pill-grey{background:#f3f4f6;color:#374151;}
.pill-pink{background:#fce7f3;color:#9d174d;} .pill-blue{background:#dbeafe;color:#1e40af;}
.pill-indigo{background:#e0e7ff;color:#3730a3;} .pill-purple{background:#ede9fe;color:#5b21b6;}

/* TABLES */
.tbl-wrap{overflow-x:auto;}
table.dcs{width:100%;border-collapse:collapse;font-size:12.5px;}
table.dcs thead th{background:#0f1923;color:#fff;padding:9px 11px;text-align:left;font-weight:600;font-size:11px;letter-spacing:.3px;white-space:nowrap;position:sticky;top:0;z-index:1;}
table.dcs tbody tr:nth-child(even){background:#fafbfd;}
table.dcs tbody tr:hover{background:#f0f9f9;}
table.dcs td{padding:9px 11px;border-bottom:1px solid var(--border);vertical-align:middle;}
table.dcs .no-data td{text-align:center;padding:40px;color:var(--muted);}
.days-overdue{color:#dc2626;font-weight:700;}

/* FORMS */
.form-group{margin-bottom:13px;}
.form-label{display:block;font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px;}
.form-control{width:100%;padding:9px 11px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-family:var(--font);color:var(--text);background:#f8fafc;outline:none;transition:border-color .2s;}
.form-control:focus{border-color:var(--pc);background:#fff;}
select.form-control{cursor:pointer;}
textarea.form-control{resize:vertical;min-height:80px;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;}
.g4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:12px;}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:7px;padding:9px 18px;border-radius:var(--radius-sm);border:none;cursor:pointer;font-size:13px;font-weight:600;transition:all .18s;font-family:var(--font);text-decoration:none;white-space:nowrap;}
.btn-primary{background:var(--pc);color:#fff;}
.btn-primary:hover{opacity:.88;transform:translateY(-1px);}
.btn-success{background:#16a34a;color:#fff;} .btn-success:hover{background:#15803d;}
.btn-danger{background:#dc2626;color:#fff;} .btn-danger:hover{background:#b91c1c;}
.btn-outline{background:transparent;border:1.5px solid var(--pc);color:var(--pc);}
.btn-outline:hover{background:var(--pc);color:#fff;}
.btn-ghost{background:transparent;border:1.5px solid var(--border);color:var(--muted);}
.btn-ghost:hover{border-color:var(--pc);color:var(--pc);}
.btn-sm{padding:5px 12px;font-size:12px;}
.btn-icon{padding:6px;width:30px;height:30px;justify-content:center;}

/* FILTER BAR */
.filter-bar{background:var(--white);border-radius:var(--radius);box-shadow:var(--shadow);padding:13px 16px;margin-bottom:14px;display:flex;flex-wrap:wrap;gap:8px;align-items:center;}
.fl{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;white-space:nowrap;}
.fs{padding:6px 9px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:12px;font-family:var(--font);background:#f8fafc;color:var(--text);outline:none;cursor:pointer;}
.fs:focus{border-color:var(--pc);}
.fsearch{padding:6px 10px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:12px;font-family:var(--font);background:#f8fafc;color:var(--text);outline:none;min-width:150px;}
.fsearch:focus{border-color:var(--pc);}

/* GRIDS */
.g-2{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.g-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;}
.g-8-4{display:grid;grid-template-columns:2fr 1fr;gap:16px;}

/* CHART BOXES */
.chart-box{position:relative;width:100%;}
.ch220{height:220px;} .ch260{height:260px;} .ch300{height:300px;}

/* IMPORT BANNER */
.import-banner{background:linear-gradient(135deg,#0f1923,#1d2d3e);border-radius:var(--radius);padding:16px 20px;margin-bottom:16px;display:flex;align-items:center;gap:16px;flex-wrap:wrap;}
.import-banner .it1{font-size:14px;font-weight:700;color:#fff;margin-bottom:2px;}
.import-banner .it2{font-size:12px;color:rgba(255,255,255,.4);}
.import-result{font-size:12px;margin-top:6px;display:none;font-weight:600;}

/* MATRIX / DISCIPLINE CARDS */
.disc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:14px;}
.disc-card{background:var(--white);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;}
.disc-card-hdr{background:#0f1923;padding:10px 14px;display:flex;align-items:center;gap:8px;}
.disc-card-type{background:var(--pc);color:#fff;font-size:13px;font-weight:800;padding:3px 10px;border-radius:5px;letter-spacing:.3px;}
.disc-card-sub{font-size:11px;color:rgba(255,255,255,.5);}
.disc-tbl{width:100%;border-collapse:collapse;font-size:12px;}
.disc-tbl th{background:rgba(0,0,0,.25);color:rgba(255,255,255,.6);font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.3px;padding:6px 10px;}
.disc-tbl td{padding:7px 10px;border-bottom:1px solid var(--border);font-weight:600;}
.disc-tbl td:first-child{background:#f8fafc;font-size:11px;font-weight:700;color:var(--text);}
.disc-tbl .dtr td{background:#0f1923;color:#fff;font-weight:800;}
.disc-tbl .dtr td:first-child{background:#1d2d3e;}

/* TABS */
.tab-bar{display:flex;gap:2px;border-bottom:2px solid var(--border);margin-bottom:16px;overflow-x:auto;}
.tab{padding:9px 16px;font-size:13px;font-weight:600;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;white-space:nowrap;transition:all .15s;}
.tab.active,.tab:hover{color:var(--pc);}
.tab.active{border-bottom-color:var(--pc);}
.tab-pane{display:none;}
.tab-pane.active{display:block;}

/* PROGRESS */
.prog-bar{background:#f3f4f6;border-radius:6px;height:7px;overflow:hidden;}
.prog-fill{height:100%;border-radius:6px;transition:width .5s ease;}

/* LOGO UPLOAD BOX */
.logo-box{width:100px;height:100px;border:2px dashed var(--border);border-radius:var(--radius-sm);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;background:#f8fafc;transition:all .2s;overflow:hidden;}
.logo-box:hover{border-color:var(--pc);background:#f0f9f9;}
.logo-box img{width:100%;height:100%;object-fit:contain;}
.logo-hint{font-size:10px;color:var(--muted);text-align:center;padding:4px;}

/* ROLE BADGES */
.role-badge{display:inline-block;padding:2px 8px;border-radius:5px;font-size:10px;font-weight:700;}
.role-super_admin{background:#1e1b4b;color:#c7d2fe;}
.role-admin{background:#0c4a6e;color:#bae6fd;}
.role-document_controller{background:#064e3b;color:#6ee7b7;}
.role-reviewer{background:#78350f;color:#fcd34d;}
.role-viewer{background:#374151;color:#d1d5db;}
.role-contractor{background:#7c2d12;color:#fed7aa;}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:500;display:none;align-items:center;justify-content:center;padding:16px;}
.modal-overlay.open{display:flex;}
.modal-box{background:var(--white);border-radius:var(--radius);box-shadow:var(--shadow-lg);width:100%;max-width:560px;max-height:90vh;overflow-y:auto;animation:mIn .22s ease;}
@keyframes mIn{from{opacity:0;transform:scale(.93);}to{opacity:1;transform:none;}}
.modal-hdr{background:#0f1923;padding:14px 18px;border-radius:var(--radius) var(--radius) 0 0;display:flex;align-items:center;justify-content:space-between;}
.modal-hdr h3{font-size:14px;font-weight:700;color:#fff;}
.modal-close{background:none;border:none;color:rgba(255,255,255,.5);font-size:20px;cursor:pointer;line-height:1;}
.modal-close:hover{color:#fff;}
.modal-body{padding:20px;}
.modal-footer{padding:12px 20px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end;}

/* PRINT */
@media print{
  @page{margin:10mm;}
  *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important;}
  .sidebar,.topbar,.filter-bar,.import-banner,.btn,.modal-overlay,.no-print,.topbar-toggle,.sidebar-overlay{display:none!important;}
  .main{margin-left:0!important;padding-top:0!important;}
  .content{padding:0!important;}
  .card,.kpi{box-shadow:none!important;border:1px solid #e5eaef!important;}
  .kpi{break-inside:avoid;}
  table.dcs thead th{background:#0f1923!important;color:#fff!important;}
  .disc-tbl .dtr td{background:#0f1923!important;color:#fff!important;}
  .disc-tbl .dtr td:first-child{background:#1d2d3e!important;}
  .print-header{display:block!important;}
  .print-footer{display:flex!important;}
}
.print-header{display:none;}
.ph-band{background:linear-gradient(135deg,var(--pc),var(--ac));border-radius:var(--radius);padding:16px 20px;margin-bottom:12px;display:flex;justify-content:space-between;align-items:flex-start;}
.ph-band h1{font-size:18px;font-weight:800;color:#fff;margin-bottom:3px;}
.ph-band .ph-sub{font-size:11px;color:rgba(255,255,255,.7);}
.ph-meta{display:flex;border:1px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;margin-bottom:12px;}
.ph-meta-item{flex:1;padding:7px 12px;border-right:1px solid var(--border);}
.ph-meta-item:last-child{border-right:none;}
.ph-meta-item strong{display:block;font-size:9px;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:2px;}
.ph-meta-item span{font-size:12px;font-weight:700;color:var(--text);}
.print-footer{display:none;margin-top:14px;padding:10px 0 0;border-top:2px solid var(--pc);justify-content:space-between;font-size:11px;color:var(--muted);}

/* RESPONSIVE */
@media(max-width:900px){
  :root{--sidebar-w:0px;}
  .sidebar{transform:translateX(-260px);}
  .sidebar.open{transform:translateX(0);}
  .sidebar-overlay.open{display:block;}
  .topbar{left:0;}
  .topbar-toggle{display:block;}
  .g-2,.g-3,.g-8-4{grid-template-columns:1fr;}
  .g3,.g4{grid-template-columns:1fr 1fr;}
}
@media(max-width:600px){
  .content{padding:12px 14px;}
  .kpi-grid{grid-template-columns:repeat(2,1fr);}
  .g2,.g3,.g4{grid-template-columns:1fr;}
  .topbar-search,.user-info{display:none;}
  table.dcs{font-size:11px;}
  table.dcs thead th,table.dcs td{padding:7px 8px;}
}
</style>
</head>
<body>
<%
const PC=settings.primary_color||'#1a7a7a';
const AC=settings.accent_color||'#23a6a6';
const PALETTE=['#1a7a7a','#6366f1','#f59e0b','#ef4444','#8b5cf6','#f97316','#34d399','#60a5fa','#ec4899','#84cc16','#06b6d4','#f43f5e','#a78bfa','#fb923c'];
const STATUS_COLOR={'Approved':'pill-green','Under Review':'pill-amber','Open':'pill-teal','Pending':'pill-orange','Rejected':'pill-red','Closed':'pill-grey','Revise & Resubmit':'pill-pink','Submitted':'pill-blue','Returned':'pill-indigo','Cancelled':'pill-grey','Draft':'pill-indigo','Issued':'pill-blue','Acknowledged':'pill-green'};
const STATUS_HEX={'Approved':'#16a34a','Under Review':'#d97706','Open':'#0f766e','Pending':'#ea580c','Rejected':'#dc2626','Closed':'#6b7280','Revise & Resubmit':'#db2777','Submitted':'#1e40af','Returned':'#4f46e5'};
function sPill(s){const cls=STATUS_COLOR[s]||'pill-grey';return `<span class="pill ${cls}">${s||'—'}</span>`;}
function sHex(s){return STATUS_HEX[s]||(PALETTE[[...( s||'x')].reduce((a,c)=>a+c.charCodeAt(0),0)%PALETTE.length]);}
function roleBadge(r){return `<span class="role-badge role-${r||'viewer'}">${(r||'viewer').replace(/_/g,' ')}</span>`;}
function fmtDate(d){return d?new Date(d).toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}):'—';}
function fmtNum(n){return (n||0).toLocaleString();}
const pageTitle=(page||'dashboard').replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase());
const isAdmin=['super_admin','admin'].includes(user.role);
const isEditor=['super_admin','admin','document_controller'].includes(user.role);
%>

<!-- PRINT HEADER/FOOTER -->
<div class="print-header">
  <div class="ph-band">
    <div><h1><%=settings.project_name%></h1><div class="ph-sub"><%=pageTitle%> &nbsp;·&nbsp; <%=settings.company_name%></div></div>
    <div style="text-align:right;color:rgba(255,255,255,.75);font-size:11px;">
      <% if(settings.project_number){%><div>Project: <%=settings.project_number%></div><%}%>
      <% if(settings.contract_number){%><div>Contract: <%=settings.contract_number%></div><%}%>
    </div>
  </div>
  <div class="ph-meta">
